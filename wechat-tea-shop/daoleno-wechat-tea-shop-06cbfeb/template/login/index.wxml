<template name="apifmLogin">
  <view class="apifmLogin" hidden="{{wxlogin}}">
    <view class="s-b">
      <view class="s-l-b">
        <image src="/images/nologin.png" />
        <text>\u5FAE\u4FE1\u6388\u6743\u767B\u5F55</text>
      </view>
      <view class="s-t-b">
        <view class="login-form">
          <button class="wx-login-btn" bindtap="processWxLogin">
            <text>\u5FAE\u4FE1\u4E00\u952E\u767B\u5F55</text>
          </button>
          <view class="divider-line">
            <view class="line"></view>
            <text class="divider-text">\u6216\u8005</text>
            <view class="line"></view>
          </view>
          <view class="form-item">
            <input type="number" placeholder="\u624B\u673A\u53F7" bindinput="onPhoneInput" value="{{loginPhone}}" maxlength="11" />
          </view>
          <view class="form-item">
            <input type="text" password placeholder="\u5BC6\u7801" bindinput="onPasswordInput" value="{{loginPassword}}" />
          </view>
          <view class="btn-row">
            <button class="phone-btn" bindtap="processPhoneLogin">\u767B\u5F55</button>
            <button class="reg-btn" bindtap="processRegister">\u6CE8\u518C</button>
          </view>
        </view>
      </view>
      <button class="c" bindtap="cancelLogin" type="default">\u6682\u4E0D\u767B\u5F55</button>
    </view>
  </view>
</template>