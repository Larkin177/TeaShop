.apifmLogin { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:99999; display:flex; align-items:center; justify-content:center; }
.apifmLogin .s-b { width:85%; background:#fff; border-radius:24rpx; padding:40rpx 0; box-shadow:0 8rpx 40rpx rgba(0,0,0,0.15); }
.apifmLogin .s-b .s-l-b { text-align:center; padding-bottom:30rpx; border-bottom:1rpx solid #f0f0f0; }
.apifmLogin .s-b .s-l-b image { width:120rpx; height:120rpx; border-radius:50%; display:block; margin:0 auto 16rpx; }
.apifmLogin .s-b .s-l-b text { font-size:36rpx; font-weight:600; color:#333; display:block; }
.apifmLogin .s-b .s-t-b { padding:30rpx 50rpx; }
.apifmLogin .s-b .wx-login-btn { width:100%; height:88rpx; line-height:88rpx; background:linear-gradient(135deg,#07c160,#06ad56); color:#fff; font-size:32rpx; border-radius:44rpx; border:none; font-weight:bold; }
.apifmLogin .s-b .wx-login-btn::after { border:none; }
.apifmLogin .s-b .divider-line { display:flex; align-items:center; margin:30rpx 0; }
.apifmLogin .s-b .divider-line .line { flex:1; height:1rpx; background:#e5e5e5; }
.apifmLogin .s-b .divider-line .divider-text { padding:0 20rpx; font-size:24rpx; color:#999; }
.apifmLogin .s-b .login-form .form-item { margin-bottom:20rpx; }
.apifmLogin .s-b .login-form .form-item input { border:2rpx solid #e5e5e5; border-radius:12rpx; padding:16rpx 20rpx; font-size:28rpx; background:#fafafa; }
.apifmLogin .s-b .btn-row { display:flex; gap:20rpx; margin-top:10rpx; }
.apifmLogin .s-b .phone-btn { flex:1; height:72rpx; line-height:72rpx; background:linear-gradient(135deg,#667eea,#764ba2); color:#fff; font-size:28rpx; border-radius:36rpx; border:none; }
.apifmLogin .s-b .phone-btn::after { border:none; }
.apifmLogin .s-b .reg-btn { flex:1; height:72rpx; line-height:72rpx; background:#fff; color:#667eea; font-size:28rpx; border:2rpx solid #667eea; border-radius:36rpx; }
.apifmLogin .s-b .c { width:80%; height:60rpx; line-height:60rpx; font-size:24rpx; background:transparent; color:#999; margin:20rpx auto 0; display:block; border:none; }
.apifmLogin .s-b .c::after { border:none; }