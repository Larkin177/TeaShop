.apifmLogin {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background-color: rgba(0,0,0,0.5);
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.apifmLogin .s-b {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 0;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
}
.apifmLogin .s-b .s-l-b {
  text-align: center;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.apifmLogin .s-b .s-l-b image {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  display: block;
  margin: 0 auto 16rpx;
}
.apifmLogin .s-b .s-l-b text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
.apifmLogin .s-b .s-t-b {
  padding: 30rpx 50rpx;
}
.apifmLogin .s-b .login-form .form-item {
  margin-bottom: 24rpx;
}
.apifmLogin .s-b .login-form .form-item .label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}
.apifmLogin .s-b .login-form .form-item input {
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #fafafa;
}
.apifmLogin .s-b button::after { border-radius: 12rpx; border: 0; }
.apifmLogin .s-b .l {
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  margin: 0 auto;
  display: block;
}
.apifmLogin .s-b .register-btn {
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 40rpx;
  margin: 16rpx auto 0;
  display: block;
}
.apifmLogin .s-b .c {
  width: 80%;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 26rpx;
  background: transparent;
  color: #999;
  margin: 16rpx auto 0;
  display: block;
}
